# ─── Backend API URL ────────────────────────────────────────────────
# Replace with your actual Render backend URL
VITE_API_URL=https://portfolio-main-3vt1.onrender.com

# ─── EmailJS (contact form + subscribe emails) ──────────────────────
# Get these from https://dashboard.emailjs.com
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# Optional: separate template for subscribe notifications
# If not set, the contact template is reused
# VITE_EMAILJS_SUBSCRIBE_TEMPLATE_ID=template_xxxxxxx
